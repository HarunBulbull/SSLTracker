# SSLTracker ortam degiskenleri. Kopyala -> .env , sunucuda doldur.
#   cp .env.example .env
# config.py bu dosyayi otomatik yukler (load_dotenv).

# --- Veri / sertifika ---
WEBTRACKER_DATA=./data
CERTBOT_USER_DIR=./certs
CERTBOT_EMAIL=info@harunbulbul.com
APP_TIMEZONE=Europe/Istanbul

# --- SMTP (mail gelmemenin #1 sebebi: bunlar bos) ---
# CloudPanel/cPanel mail hesabi bilgileri.
SMTP_HOST=mail.ornekdomain.com
SMTP_PORT=587
SMTP_USERNAME=uyari@ornekdomain.com
SMTP_PASSWORD=super-secret
# 587 -> TLS=true SSL=false   |   465 -> TLS=false SSL=true
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=uyari@ornekdomain.com
# Virgulle birden cok alici
SMTP_TO_EMAILS=admin@ornekdomain.com

# --- SSL uyari cron ---
SSL_ALERT_THRESHOLD_DAYS=2
SSL_ALERT_CRON_HOUR=9
SSL_ALERT_CRON_MINUTE=0
